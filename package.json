{
  "name": "pnpm-airgap",
  "version": "2.2.0",
  "description": "Transfer pnpm project dependencies between online and offline environments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pnpm-airgap": "dist/cli.cjs"
  },
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "pnpm",
    "offline",
    "airgap",
    "verdaccio",
    "npm",
    "registry",
    "dependencies",
    "air-gapped",
    "mirror",
    "sync"
  ],
  "author": "Reem Assaf reemasaf44@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReemX/pnpm-airgap.git"
  },
  "homepage": "https://github.com/ReemX/pnpm-airgap#readme",
  "bugs": {
    "url": "https://github.com/ReemX/pnpm-airgap/issues"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "axios": "^1.13.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "fs-extra": "^11.3.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.0.0",
    "p-limit": "^7.2.0",
    "tar": "^7.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.3",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  }
}
